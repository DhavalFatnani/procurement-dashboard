{
  "name": "knot-procurement",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:sync-auth-users": "dotenv -e .env.local -- tsx scripts/sync-auth-users.ts",
    "db:reset-fresh": "dotenv -e .env.local -- tsx scripts/reset-operational-data.ts",
    "db:generate": "prisma generate",
    "storage:setup": "dotenv -e .env.local -- tsx scripts/ensure-storage-buckets.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@number-flow/react": "^0.6.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8",
    "eslint-config-next": "^15.3.3",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
