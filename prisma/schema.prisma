generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (CLI/migrations) and are
  // passed to PrismaClient via `accelerateUrl` at runtime (see lib/prisma.ts).
}

// --- ENUMS ---

enum Role {
  SM
  OPS_HEAD
  FINANCE
  ADMIN
}

enum PRStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVISION_REQUIRED
  CONVERTED_TO_PO
  EXECUTED_PRINT
  CANCELLED
  FORCE_CANCELLED
}

enum ExecutionType {
  VENDOR_PURCHASE
  INTERNAL_PRINT
}

enum POStatus {
  OPEN
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  INVOICED
  PAID
  CLOSED
  PARTIALLY_CLOSED
  FORCE_CLOSED
}

enum GRNExceptionType {
  DAMAGED
  WRONG_ITEM
  QUANTITY_SHORT
  QUALITY_REJECTION
}

enum GRNExceptionResolution {
  ACCEPTED
  RETURNED_TO_VENDOR
  OVERRIDE_ACCEPTED
}

/// Physical handling of disputed qty at resolve time.
enum GRNExceptionDisposition {
  KEEP
  RETURN_TO_VENDOR
  /// Disputed qty removed from receipt; not sent back (e.g. damaged). Pair with close-line to reduce PO commitment.
  NOT_RETURNED
}

/// Ops resolution outcome (four scenarios; replaces disposition × commitment in UI).
enum GRNExceptionOutcome {
  ACCEPT_AT_PO_PRICE
  ACCEPT_AT_DISPUTED_PRICE
  RETURN_AND_SETTLE
  REPLACE_AND_AWAIT_GRN
}

enum CatalogItemKind {
  BASE
  DISPUTED
}

enum InvoiceMatchStatus {
  PENDING
  MATCHED
  MISMATCH
  OVERRIDE_ACCEPTED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum POAdvanceRequestStatus {
  PENDING
  CANCELLED
  REJECTED
  FULFILLED
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VendorRequestStatus {
  PENDING
  ACTIVATED
  REJECTED
}

enum SerialReservationStatus {
  PENDING
  RESERVED
  RELEASED
}

enum SerialReservationPurpose {
  INTERNAL_PRINT
  VENDOR_LOCK_TAGS
  ADMIN_BLOCK
}

enum AdminAuditAction {
  SERIAL_BLOCK
  SERIAL_RELEASE
  SERIAL_REASSIGN
  SERIAL_SPLIT
  SERIAL_MERGE
  LIFECYCLE_RELEASE
  SERIES_CONFIG_CREATE
  SERIES_CONFIG_UPDATE
  SERIES_CONFIG_RESET
  SERIES_CONFIG_DEACTIVATE
}

enum CatalogItemStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  INACTIVE
}

enum CategoryBillingGranularity {
  CATALOG_ITEM
  SUBCATEGORY
}

enum TaxonomyStatus {
  ACTIVE
  INACTIVE
}

enum VendorItemPriceSource {
  PO
  CONFIGURE
}

/// Reserved for operational/UI state around serial ceilings (not yet on `SeriesConfig` per domain spec).
enum SeriesConfigStatus {
  ACTIVE
  INACTIVE
  WARNING
}

// --- MODELS ---

model User {
  id          String     @id
  email       String     @unique
  name        String
  role        Role
  status      UserStatus @default(ACTIVE)
  warehouseId String
  createdAt   DateTime   @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  warehouseAssignments UserWarehouse[]

  vendorsCreated            Vendor[]            @relation("VendorCreatedBy")
  vendorChangeLogs          VendorChangeLog[]
  vendorRequestsRequested   VendorRequest[]     @relation("VendorRequestRequestedBy")
  vendorRequestsReviewed    VendorRequest[]     @relation("VendorRequestReviewedBy")
  purchaseRequestsCreated   PurchaseRequest[]
  prVersionsChanged         PRVersion[]
  purchaseOrdersForceClosed PurchaseOrder[]     @relation("POForceClosedBy")
  goodsReceipts             GoodsReceipt[]
  grnExceptionsResolved     GRNException[]
  invoicesUploaded          Invoice[]           @relation("InvoiceUploadedBy")
  invoicesOverridden        Invoice[]           @relation("InvoiceOverrideBy")
  paymentsPaid              Payment[]
  poAdvanceRequests         POAdvanceRequest[] @relation("POAdvanceRequestedBy")
  poAdvanceRequestsReviewed POAdvanceRequest[] @relation("POAdvanceReviewedBy")
  poAdvancePaymentsPaid     POAdvancePayment[] @relation("POAdvancePaidBy")
  poLineAdjustmentsCreated  PurchaseOrderLineAdjustment[] @relation("POLineAdjustmentCreatedBy")
  serialReservationsCreated SerialReservation[] @relation("SerialReservationCreatedBy")
  serialReservationsReleased SerialReservation[] @relation("SerialReservationReleasedBy")
  adminAuditLogs            AdminAuditLog[]
  seriesConfigsConfigured   SeriesConfig[]
  catalogItemsCreated       CatalogItem[]       @relation("CatalogItemCreatedBy")
  catalogItemsApproved      CatalogItem[]       @relation("CatalogItemApprovedBy")
  catalogItemVendorsLinked  CatalogItemVendor[] @relation("CatalogItemVendorLinkedBy")
  vendorCatalogItemPrices   VendorCatalogItemPrice[] @relation("VendorCatalogItemPriceRecordedBy")

  @@index([role])
  @@index([status])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())

  users              User[]
  userAssignments    UserWarehouse[]
  purchaseRequests   PurchaseRequest[]
  serialReservations SerialReservation[]
}

model UserWarehouse {
  userId      String
  warehouseId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([userId, warehouseId])
  @@index([warehouseId])
}

model Vendor {
  id                   String       @id @default(cuid())
  businessName         String
  gst                  String?
  address              String?
  pocName              String
  phone                String
  email                String
  accountName          String
  accountNumber        String
  ifsc                 String
  bankName             String
  status               VendorStatus @default(ACTIVE)
  hasSimilarVendorFlag Boolean      @default(false)
  similarVendorId      String?
  createdById          String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  createdBy User     @relation("VendorCreatedBy", fields: [createdById], references: [id])
  similarTo Vendor?  @relation("VendorSimilarity", fields: [similarVendorId], references: [id])
  similarOf Vendor[] @relation("VendorSimilarity")

  purchaseOrders          PurchaseOrder[]
  vendorChangeLogs        VendorChangeLog[]
  vendorRequestsActivated VendorRequest[]   @relation("VendorRequestActivatedVendor")
  purchaseRequests        PurchaseRequest[]
  catalogItemLinks        CatalogItemVendor[]
  catalogItemPrices       VendorCatalogItemPrice[]

  @@index([status])
  @@index([updatedAt])
  @@index([createdById])
}

model VendorChangeLog {
  id          String   @id @default(cuid())
  vendorId    String
  fieldName   String
  oldValue    String?
  newValue    String?
  changedById String
  changedAt   DateTime @default(now())
  reason      String?

  vendor    Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([vendorId])
  @@index([changedById])
}

model VendorRequest {
  id                String              @id @default(cuid())
  businessName      String
  pocName           String
  phone             String
  email             String
  status            VendorRequestStatus @default(PENDING)
  requestedById     String
  reviewedById      String?
  reviewReason      String?
  linkedPRId        String?             @unique
  activatedVendorId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  requestedBy     User             @relation("VendorRequestRequestedBy", fields: [requestedById], references: [id])
  reviewedBy      User?            @relation("VendorRequestReviewedBy", fields: [reviewedById], references: [id])
  linkedPR        PurchaseRequest? @relation("VendorRequestLinkedPR", fields: [linkedPRId], references: [id])
  activatedVendor Vendor?          @relation("VendorRequestActivatedVendor", fields: [activatedVendorId], references: [id])
  purchaseRequest PurchaseRequest? @relation("PurchaseRequestVendorRequest")

  @@index([status])
}

model Category {
  id                 String                   @id @default(cuid())
  name               String                   @unique
  billingGranularity CategoryBillingGranularity
  status             TaxonomyStatus           @default(ACTIVE)

  subcategories         Subcategory[]
  purchaseRequests         PurchaseRequest[]
  purchaseRequestLines     PurchaseRequestLine[]
  purchaseOrderLines       PurchaseOrderLine[]
  purchaseOrderLineItems   PurchaseOrderLineItem[]
}

model Subcategory {
  id            String         @id @default(cuid())
  categoryId    String
  name          String
  series        String?
  executionType ExecutionType
  status        TaxonomyStatus @default(ACTIVE)

  category              Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  seriesConfig          SeriesConfig?          @relation(fields: [series], references: [code], onDelete: SetNull)
  purchaseRequests         PurchaseRequest[]
  purchaseRequestLines     PurchaseRequestLine[]
  purchaseOrderLines       PurchaseOrderLine[]
  purchaseOrderLineItems   PurchaseOrderLineItem[]
  catalogItems             CatalogItem[]

  @@unique([categoryId, name])
}

model CatalogItem {
  id                String            @id @default(cuid())
  subcategoryId     String
  name              String
  sku               String?
  unit              String            @default("pcs")
  kind              CatalogItemKind   @default(BASE)
  baseCatalogItemId String?
  status            CatalogItemStatus @default(PENDING_APPROVAL)
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  rejectedReason    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  subcategory       Subcategory               @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  baseCatalogItem   CatalogItem?              @relation("CatalogDisputeVariant", fields: [baseCatalogItemId], references: [id], onDelete: SetNull)
  disputeVariants   CatalogItem[]             @relation("CatalogDisputeVariant")
  createdBy         User                      @relation("CatalogItemCreatedBy", fields: [createdById], references: [id])
  approvedBy        User?                     @relation("CatalogItemApprovedBy", fields: [approvedById], references: [id])
  prLineItems       PurchaseRequestLineItem[]
  poLineItems       PurchaseOrderLineItem[]
  vendorLinks       CatalogItemVendor[]
  vendorPrices      VendorCatalogItemPrice[]
  grnExceptionsAsVariant GRNException[]       @relation("GRNExceptionDisputeVariant")

  @@unique([subcategoryId, name])
  @@index([subcategoryId, status])
  @@index([createdById])
  @@index([baseCatalogItemId, kind])
}

model CatalogItemVendor {
  catalogItemId String
  vendorId      String
  firstLinkedAt DateTime @default(now())
  lastLinkedAt  DateTime @updatedAt
  linkedById    String?

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  linkedBy    User?       @relation("CatalogItemVendorLinkedBy", fields: [linkedById], references: [id])

  @@id([catalogItemId, vendorId])
  @@index([vendorId])
}

model VendorCatalogItemPrice {
  id            String                @id @default(cuid())
  catalogItemId String
  vendorId      String
  unitPrice     Decimal               @db.Decimal(18, 4)
  source        VendorItemPriceSource
  poId          String?
  prId          String?
  recordedById  String
  recordedAt    DateTime              @default(now())
  notes         String?

  catalogItem CatalogItem    @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  vendor      Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: SetNull)
  purchaseRequest PurchaseRequest? @relation(fields: [prId], references: [id], onDelete: SetNull)
  recordedBy  User           @relation("VendorCatalogItemPriceRecordedBy", fields: [recordedById], references: [id])

  @@index([catalogItemId, vendorId, recordedAt(sort: Desc)])
  @@index([vendorId])
  @@index([poId])
}

/// Human-facing id: use prefix `PR-` in application (e.g. `PR-${cuid()}`) when creating rows.
model PurchaseRequest {
  id              String        @id
  /// Legacy header fields — prefer `lines`. Kept for internal-print single-item rows.
  categoryId      String?
  subcategoryId   String?
  quantity        Int?
  warehouseId     String
  vendorId        String?
  executionType   ExecutionType
  status          PRStatus      @default(DRAFT)
  currentVersion  Int           @default(1)
  revisionCount   Int           @default(0)
  vendorRequestId String?       @unique
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category      Category?      @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  vendorRequest VendorRequest? @relation("PurchaseRequestVendorRequest", fields: [vendorRequestId], references: [id])
  createdBy     User           @relation(fields: [createdById], references: [id])

  lines                PurchaseRequestLine[]
  linkedVendorRequests VendorRequest[]       @relation("VendorRequestLinkedPR")
  versions             PRVersion[]
  purchaseOrders       PurchaseOrder[]
  serialReservation    SerialReservation?
  vendorCatalogItemPrices VendorCatalogItemPrice[]

  @@index([status])
  @@index([warehouseId, status])
  @@index([warehouseId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([executionType, status])
  @@index([createdById])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([vendorId])
  // Awaiting-PO panel and inbox "recent" group order approved PRs by updatedAt desc.
  @@index([updatedAt])
}

model PurchaseRequestLine {
  id            String  @id @default(cuid())
  prId          String
  lineNumber    Int
  categoryId    String
  subcategoryId String
  /// Legacy / internal-print fallback — vendor qty is on `items`.
  quantity      Int?
  notes         String?

  purchaseRequest   PurchaseRequest            @relation(fields: [prId], references: [id], onDelete: Cascade)
  category          Category                   @relation(fields: [categoryId], references: [id])
  subcategory       Subcategory                @relation(fields: [subcategoryId], references: [id])
  items             PurchaseRequestLineItem[]
  purchaseOrderLine PurchaseOrderLine?

  @@unique([prId, lineNumber])
  @@index([prId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model PurchaseRequestLineItem {
  id             String @id @default(cuid())
  prLineId       String
  catalogItemId  String
  lineItemNumber Int
  quantity       Int

  prLine      PurchaseRequestLine      @relation(fields: [prLineId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem              @relation(fields: [catalogItemId], references: [id])
  poLineItem  PurchaseOrderLineItem?

  @@unique([prLineId, catalogItemId])
  @@unique([prLineId, lineItemNumber])
  @@index([prLineId])
  @@index([catalogItemId])
}

model PRVersion {
  id              String   @id @default(cuid())
  prId            String
  versionNumber   Int
  changedById     String
  changedAt       DateTime @default(now())
  revisionComment String?
  diffSnapshot    Json?

  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  changedBy User            @relation(fields: [changedById], references: [id])

  @@index([prId])
}

/// Human-facing id: use prefix `PO-` when creating rows.
model PurchaseOrder {
  id               String    @id
  prId             String
  vendorId         String
  /// Legacy totals — prefer summing `lines`. Kept for list queries during transition.
  orderedQty       Int?
  unitPrice        Decimal?  @db.Decimal(18, 4)
  status           POStatus  @default(OPEN)
  expectedDelivery DateTime?
  deliveryComplete Boolean   @default(false)
  /// When true, unit prices are exclusive of GST and gstRatePercent applies.
  gstApplicable    Boolean   @default(false)
  gstRatePercent   Decimal?  @db.Decimal(5, 2)
  forceClosedById  String?
  forceCloseReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseRequest PurchaseRequest @relation(fields: [prId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  forceClosedBy   User?           @relation("POForceClosedBy", fields: [forceClosedById], references: [id])

  lines             PurchaseOrderLine[]
  lineItems         PurchaseOrderLineItem[]
  grns              GoodsReceipt[]
  invoices          Invoice[]
  serialReservation SerialReservation?
  catalogItemPrices VendorCatalogItemPrice[]
  advanceRequests   POAdvanceRequest[]
  advancePayments   POAdvancePayment[]
  lineAdjustments   PurchaseOrderLineAdjustment[]

  @@index([prId])
  @@index([status])
  @@index([vendorId])
  @@index([createdAt])
  @@index([status, createdAt])
  // Inbox ("POs to receive"/"at risk") and dashboard recent-activity order by updatedAt desc.
  @@index([updatedAt])
}

model POAdvanceRequest {
  id               String                 @id @default(cuid())
  poId             String
  requestedAmount  Decimal                @db.Decimal(18, 4)
  requestedPercent Decimal?               @db.Decimal(6, 3)
  reason           String
  status           POAdvanceRequestStatus @default(PENDING)
  requestedById    String
  requestedAt      DateTime               @default(now())
  reviewedById     String?
  reviewReason     String?
  updatedAt        DateTime               @updatedAt

  purchaseOrder PurchaseOrder       @relation(fields: [poId], references: [id], onDelete: Cascade)
  requestedBy   User                @relation("POAdvanceRequestedBy", fields: [requestedById], references: [id])
  reviewedBy    User?               @relation("POAdvanceReviewedBy", fields: [reviewedById], references: [id])
  payment       POAdvancePayment?

  @@index([poId])
  @@index([status])
  @@index([requestedAt])
}

model POAdvancePayment {
  id             String   @id @default(cuid())
  poId           String
  requestId      String   @unique
  amount         Decimal  @db.Decimal(18, 4)
  method         String?
  transactionRef String
  proofUrl       String?
  paidById       String
  paidAt         DateTime
  createdAt      DateTime @default(now())

  purchaseOrder PurchaseOrder          @relation(fields: [poId], references: [id], onDelete: Cascade)
  request       POAdvanceRequest       @relation(fields: [requestId], references: [id], onDelete: Restrict)
  paidBy        User                   @relation("POAdvancePaidBy", fields: [paidById], references: [id])
  allocations   POAdvanceAllocation[]

  @@index([poId])
  @@index([paidAt])
}

model POAdvanceAllocation {
  id               String  @id @default(cuid())
  advancePaymentId String
  invoiceId        String
  amount           Decimal @db.Decimal(18, 4)
  createdAt        DateTime @default(now())

  advancePayment POAdvancePayment @relation(fields: [advancePaymentId], references: [id], onDelete: Cascade)
  invoice        Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([advancePaymentId])
  @@index([invoiceId])
}

model PurchaseOrderLine {
  id            String  @id @default(cuid())
  poId          String
  prLineId      String  @unique
  categoryId    String
  subcategoryId String
  orderedQty    Int
  unitPrice     Decimal @db.Decimal(18, 4)

  purchaseOrder   PurchaseOrder       @relation(fields: [poId], references: [id], onDelete: Cascade)
  prLine          PurchaseRequestLine @relation(fields: [prLineId], references: [id])
  category        Category            @relation(fields: [categoryId], references: [id])
  subcategory     Subcategory         @relation(fields: [subcategoryId], references: [id])
  goodsReceiptLines GoodsReceiptLine[]
  grnExceptions     GRNException[]
  lineAdjustments   PurchaseOrderLineAdjustment[]

  @@index([poId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model PurchaseOrderLineItem {
  id                       String  @id @default(cuid())
  poId                     String
  prLineItemId             String? @unique
  catalogItemId            String
  categoryId               String
  subcategoryId            String
  orderedQty               Int
  unitPrice                Decimal @db.Decimal(18, 4)
  sourcePoLineItemId       String?
  originatingGrnExceptionId String? @unique

  purchaseOrder            PurchaseOrder              @relation(fields: [poId], references: [id], onDelete: Cascade)
  prLineItem               PurchaseRequestLineItem?   @relation(fields: [prLineItemId], references: [id])
  catalogItem              CatalogItem                @relation(fields: [catalogItemId], references: [id])
  category                 Category                   @relation(fields: [categoryId], references: [id])
  subcategory              Subcategory                @relation(fields: [subcategoryId], references: [id])
  sourcePoLineItem         PurchaseOrderLineItem?     @relation("POLineDisputeSplit", fields: [sourcePoLineItemId], references: [id], onDelete: SetNull)
  disputeSplitLines        PurchaseOrderLineItem[]    @relation("POLineDisputeSplit")
  originatingGrnException    GRNException?              @relation("POLineFromGrnException", fields: [originatingGrnExceptionId], references: [id], onDelete: SetNull)
  goodsReceiptLineItems    GoodsReceiptLineItem[]
  grnExceptions            GRNException[]
  lineAdjustments          PurchaseOrderLineAdjustment[]

  @@index([poId])
  @@index([catalogItemId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([sourcePoLineItemId])
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  poId            String
  receivedQty     Int
  acceptedQty     Int
  disputedQty     Int      @default(0)
  receivedById    String
  receivedAt      DateTime @default(now())
  deliveryNoteRef String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  receivedBy    User          @relation(fields: [receivedById], references: [id])

  exceptions   GRNException[]
  invoiceLinks InvoiceGRNLink[]
  lines        GoodsReceiptLine[]
  lineItems    GoodsReceiptLineItem[]

  @@index([poId])
  @@index([receivedAt])
  // FK used by receivedBy joins and "received by me" filters; Postgres does not auto-index FKs.
  @@index([receivedById])
}

model GoodsReceiptLineItem {
  id           String @id @default(cuid())
  grnId        String
  poLineItemId String
  receivedQty  Int
  acceptedQty  Int
  disputedQty  Int    @default(0)

  goodsReceipt          GoodsReceipt          @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderLineItem PurchaseOrderLineItem @relation(fields: [poLineItemId], references: [id])

  @@unique([grnId, poLineItemId])
  @@index([grnId])
  @@index([poLineItemId])
}

model GoodsReceiptLine {
  id           String @id @default(cuid())
  grnId        String
  poLineId     String
  receivedQty  Int
  acceptedQty  Int
  disputedQty  Int    @default(0)

  goodsReceipt    GoodsReceipt    @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [poLineId], references: [id])

  @@unique([grnId, poLineId])
  @@index([grnId])
  @@index([poLineId])
}

model GRNException {
  id                        String                  @id @default(cuid())
  grnId                     String
  poLineItemId              String?
  poLineId                  String?
  exceptionType             GRNExceptionType
  exceptionQty              Int
  note                      String
  resolutionStatus          GRNExceptionResolution?
  resolutionOutcome         GRNExceptionOutcome?
  resolutionDisposition     GRNExceptionDisposition?
  closeLineAfterResolve     Boolean?
  pendingReplacementQty     Int?
  disputeVariantCatalogItemId String?
  resolvedById              String?
  resolvedAt                DateTime?
  resolutionNote            String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @default(now()) @updatedAt

  grn                       GoodsReceipt            @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderLineItem     PurchaseOrderLineItem?  @relation(fields: [poLineItemId], references: [id], onDelete: SetNull)
  purchaseOrderLine         PurchaseOrderLine?      @relation(fields: [poLineId], references: [id], onDelete: SetNull)
  disputeVariantCatalogItem CatalogItem?            @relation("GRNExceptionDisputeVariant", fields: [disputeVariantCatalogItemId], references: [id], onDelete: SetNull)
  resolvedBy                User?                   @relation(fields: [resolvedById], references: [id])
  lineAdjustment            PurchaseOrderLineAdjustment?
  disputeSplitPoLineItem    PurchaseOrderLineItem?  @relation("POLineFromGrnException")

  @@index([grnId])
  @@index([poLineItemId])
  @@index([poLineId])
  // Inbox "open exceptions" filters `exceptions: { some: { resolutionStatus: null } }`.
  @@index([resolutionStatus])
  @@index([resolutionOutcome])
}

/// Effective qty/price after dispute resolution (original PO line values stay immutable).
model PurchaseOrderLineAdjustment {
  id                  String   @id @default(cuid())
  poId                String
  poLineItemId        String?
  poLineId            String?
  grnExceptionId      String   @unique
  originalOrderedQty  Int
  effectiveOrderedQty Int
  originalUnitPrice   Decimal  @db.Decimal(18, 4)
  effectiveUnitPrice  Decimal  @db.Decimal(18, 4)
  reason              String
  createdById         String
  createdAt           DateTime @default(now())

  purchaseOrder         PurchaseOrder          @relation(fields: [poId], references: [id], onDelete: Cascade)
  purchaseOrderLineItem PurchaseOrderLineItem? @relation(fields: [poLineItemId], references: [id], onDelete: SetNull)
  purchaseOrderLine     PurchaseOrderLine?     @relation(fields: [poLineId], references: [id], onDelete: SetNull)
  grnException          GRNException           @relation(fields: [grnExceptionId], references: [id], onDelete: Cascade)
  createdBy             User                   @relation("POLineAdjustmentCreatedBy", fields: [createdById], references: [id])

  @@index([poId])
  @@index([poLineItemId])
  @@index([poLineId])
  @@index([createdAt])
}

model Invoice {
  id             String             @id @default(cuid())
  poId           String
  invoiceNumber  String
  amount         Decimal            @db.Decimal(18, 4)
  invoiceDate    DateTime
  fileUrl        String
  uploadedById   String
  matchStatus    InvoiceMatchStatus @default(PENDING)
  expectedAmount Decimal?           @db.Decimal(18, 4)
  tolerancePct   Decimal            @default(2.5) @db.Decimal(6, 3)
  overrideById   String?
  overrideReason String?
  paymentStatus  PaymentStatus      @default(UNPAID)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  uploadedBy    User          @relation("InvoiceUploadedBy", fields: [uploadedById], references: [id])
  overrideBy    User?         @relation("InvoiceOverrideBy", fields: [overrideById], references: [id])

  grnLinks            InvoiceGRNLink[]
  payments            Payment[]
  advanceAllocations  POAdvanceAllocation[]

  @@unique([poId, invoiceNumber])
  @@index([createdAt])
  @@index([paymentStatus])
  // Finance inbox orders invoices by updatedAt desc and filters by matchStatus;
  // invoice list also filters by uploadedById. None were covered before.
  @@index([updatedAt])
  @@index([matchStatus])
  @@index([uploadedById])
}

model InvoiceGRNLink {
  id        String @id @default(cuid())
  invoiceId String
  grnId     String

  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  grn     GoodsReceipt @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, grnId])
  @@index([grnId])
}

model Payment {
  id             String        @id @default(cuid())
  invoiceId      String
  status         PaymentStatus
  amount         Decimal?      @db.Decimal(18, 4)
  method         String?
  proofUrl       String?
  transactionRef String?
  paidById       String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paidBy  User?   @relation(fields: [paidById], references: [id])

  @@index([invoiceId])
  // Recent-activity and finance-recent feeds order payments by createdAt desc;
  // paidById is an unindexed FK used by paidBy joins.
  @@index([createdAt])
  @@index([paidById])
}

model SerialReservation {
  id             String                   @id @default(cuid())
  series         String
  rangeStart     BigInt
  rangeEnd       BigInt
  quantity       Int
  warehouseId    String?
  status         SerialReservationStatus  @default(PENDING)
  purpose        SerialReservationPurpose @default(INTERNAL_PRINT)
  prId           String?                  @unique
  poId           String?                  @unique
  idempotencyKey String                   @unique
  createdById    String
  releasedAt     DateTime?
  releasedById   String?
  releaseReason  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @default(now()) @updatedAt

  warehouse    Warehouse?       @relation(fields: [warehouseId], references: [id])
  pr           PurchaseRequest? @relation(fields: [prId], references: [id])
  po           PurchaseOrder?   @relation(fields: [poId], references: [id])
  seriesConfig SeriesConfig     @relation(fields: [series], references: [code])
  createdBy    User             @relation("SerialReservationCreatedBy", fields: [createdById], references: [id])
  releasedBy   User?            @relation("SerialReservationReleasedBy", fields: [releasedById], references: [id])

  @@index([series])
  @@index([warehouseId])
  @@index([createdById])
  @@index([releasedById])
  @@index([status])
}

model AdminAuditLog {
  id         String           @id @default(cuid())
  actorId    String
  action     AdminAuditAction
  targetType String
  targetId   String?
  reason     String
  metadata   Json?
  createdAt  DateTime         @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model SeriesConfig {
  id                      String   @id @default(cuid())
  code                    String   @unique
  displayName             String
  prefixPattern           String
  rangeStart              BigInt
  inactivityThresholdDays Int      @default(30)
  ceilingNumber           BigInt
  ceilingAlertPct         Int      @default(80)
  sortOrder               Int      @default(0)
  isActive                Boolean  @default(true)
  configuredById          String
  configuredAt            DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  configuredBy         User                @relation(fields: [configuredById], references: [id])
  serialReservations     SerialReservation[]
  subcategories          Subcategory[]

  @@index([isActive, sortOrder])
}
