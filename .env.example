NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Dashboard → Settings → API Keys: publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only — never NEXT_PUBLIC. Replaces legacy service_role JWT.
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy JWT keys (optional migration fallback — prefer publishable + secret above)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Database — choose URL by environment (see lib/db-parallel.ts):
#
# Local dev (faster): session pooler port 5432 with connection_limit=5 enables parallel queries.
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres?connection_limit=5&pool_timeout=30"
#
# Production (Vercel): use Prisma Accelerate — set DATABASE_URL to prisma://… from the
# Accelerate dashboard. Do NOT use the Supabase session pooler (port 5432) on serverless;
# concurrent lambdas exhaust pool_size and crash RSC pages after login.
#
# Default / transaction pooler (6543): serial queries only — one connection at a time.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30"
# Dev only: run up to 3 concurrent reads when DATABASE_URL is postgresql:// (not prisma://).
# Requires connection_limit>1 on the pooler; omit with transaction pooler connection_limit=1.
ALLOW_LOCAL_DB_PARALLEL=true
# Migrations: prefer session pooler on the same host as DATABASE_URL (port 5432).
# db.YOUR_PROJECT_REF.supabase.co often resolves to IPv6-only; use direct host only if Connect shows IPv4.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres"

# Required by `prisma db seed` to provision seed auth users. The seed throws if unset.
SEED_AUTH_PASSWORD=choose-a-strong-password

# Migrations on Supabase: use deploy (no shadow DB). `db:migrate` (migrate dev) fails with P3006
# if the DB was first created with `db push` — only index migrations exist, no baseline.
# npm run db:migrate:deploy

# After linking Supabase, create private storage buckets (fixes "Bucket not found" on upload):
# npm run storage:setup
